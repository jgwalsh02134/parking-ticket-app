# ─────────────────────────────────────────────────────────────
# Albany Parking Ticket Appeal — Environment Variables
# Copy this file to ".env" for local dev, or set these in Railway.
# ALL variables are OPTIONAL. The app runs fully without them.
# ─────────────────────────────────────────────────────────────

# Port the server listens on.
# Railway sets this automatically — do NOT set it yourself on Railway.
# For local dev it defaults to 5000 if unset.
# PORT=5000

# ── Photo auto-fill (OCR) — OPTIONAL ──
# The "snap a photo of your ticket" auto-fill feature uses OpenAI vision.
# If you DON'T set a key, the app degrades gracefully: it simply asks the
# user to type the ticket fields by hand. Everything else works without it.
#
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Vision model used for OCR. Optional. Defaults to "gpt-4o".
# OPENAI_VISION_MODEL=gpt-4o
